#!/bin/sh
# 在 opkg 覆盖 language/text/default 之前，备份当前文件（通常为原版英文）
[ "${IPKG_NO_SCRIPT}" = "1" ] && exit 0

TEXT=/etc/gl_screen/language/text/default
BACKUP="${TEXT}.opkg-dist"

case "$1" in
install)
	if [ ! -f "$BACKUP" ] && [ -f "$TEXT" ]; then
		cp "$TEXT" "$BACKUP"
	fi
	;;
upgrade)
	# 保留首次安装时备份，避免把中文版当成“原版”
	;;
esac

exit 0
