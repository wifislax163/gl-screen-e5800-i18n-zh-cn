#!/bin/sh
# opkg 会先删除包内文件（含中文版 default），再在 postrm 从备份还原英文
[ "${IPKG_NO_SCRIPT}" = "1" ] && exit 0

TEXT=/etc/gl_screen/language/text/default
BACKUP="${TEXT}.opkg-dist"

case "$1" in
remove|purge)
	if [ -f "$BACKUP" ]; then
		cp "$BACKUP" "$TEXT"
		rm -f "$BACKUP"
		[ -x /etc/init.d/gl_screen ] && /etc/init.d/gl_screen restart
	fi
	;;
esac

exit 0
